	cd /home/s886374/kvoffload/ascend-kernel/build && $(MAKE) $(MAKESILENT) -f csrc/CMakeFiles/ascend_kernel.dir/build.make csrc/CMakeFiles/ascend_kernel.dir/register.cpp.o
.PHONY : register.cpp.o

register.i: register.cpp.i
.PHONY : register.i

# target to preprocess a source file
register.cpp.i:
	cd /home/s886374/kvoffload/ascend-kernel/build && $(MAKE) $(MAKESILENT) -f csrc/CMakeFiles/ascend_kernel.dir/build.make csrc/CMakeFiles/ascend_kernel.dir/register.cpp.i
.PHONY : register.cpp.i

register.s: register.cpp.s
.PHONY : register.s

# target to generate assembly for a file
register.cpp.s:
	cd /home/s886374/kvoffload/ascend-kernel/build && $(MAKE) $(MAKESILENT) -f csrc/CMakeFiles/ascend_kernel.dir/build.make csrc/CMakeFiles/ascend_kernel.dir/register.cpp.s
.PHONY : register.cpp.s

